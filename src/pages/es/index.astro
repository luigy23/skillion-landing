---
import Layout from '../../layouts/Layout.astro';
import PreRegisterForm from '../../components/PreRegisterForm.astro';
import FeatureCard from '../../components/FeatureCard.astro';
import ParallaxHero from '../../components/ParallaxHero.astro';
import ParallaxProductivity from '../../components/ParallaxProductivity.astro';
import { Image } from 'astro:assets';
import Logo from '../../assets/Skillion.png';
import Background from '../../assets/bgHero.png';

---

<Layout 
    lang="es"
    title="Skillion - Gamifica tu Vida Real | App RPG de Hábitos y Productividad"
    description="🎮 Skillion convierte tus hábitos en un RPG épico. Gana XP real, sube de nivel en la vida y derrota la procrastinación. La app de gamificación más divertida para mejorar tu productividad y crear hábitos duraderos."
>
    <main class="bg-pixel-gradient text-pixel-text">
        <script>
        {`
          (function(){
            try {
              var ua = navigator.userAgent.toLowerCase();
              var isBot = /(bot|crawler|spider|crawling)/.test(ua);
              if (isBot) return;
              var pref = null;
              try { pref = localStorage.getItem('preferredLang'); } catch(e) {}
              if (window.location.pathname === '/es/' || window.location.pathname === '/es') {
                if (pref === 'en') {
                  window.location.replace('/');
                  return;
                }
              }
            } catch(e) {}
          })();
        `}
        </script>
        
        <!-- Sección 1: Héroe de la Aventura con Parallax -->
        <ParallaxHero lang="es" />

        <!-- Sección 2: El Problema -->
        <section class="py-20 px-4 bg-pixel-bg2 hidden">
            <div class="container mx-auto text-center">
                <div class="max-w-4xl mx-auto">
                    <h2 class="text-3xl md:text-5xl font-bold mb-8 font-poppins">
                        ¿Las apps de hábitos te <span class="text-gaming-health">aburren</span>?
                        <br>
                        ¿La motivación no te <span class="text-gaming-health">dura</span>?
                    </h2>
                    
                    <div class="bg-pixel-card border-2 border-pixel-border shadow-pixel p-8 mb-8">
                        <div class="text-6xl mb-4">😴</div>
                        <p class="text-xl text-pixel-text-secondary leading-relaxed font-poppins">
                            Dejar de procrastinar no debería ser un castigo. Las listas de tareas son aburridas 
                            y no reflejan tu progreso real. Es hora de un cambio.
                        </p>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="bg-pixel-card border-2 border-red-600 p-6 shadow-pixel">
                            <div class="text-3xl mb-2">❌</div>
                            <h3 class="font-bold text-gaming-health mb-2">Aburrido</h3>
                            <p class="text-sm text-pixel-text-secondary">Solo listas y checks</p>
                        </div>
                        <div class="bg-pixel-card border-2 border-red-600 p-6 shadow-pixel">
                            <div class="text-3xl mb-2">📉</div>
                            <h3 class="font-bold text-gaming-health mb-2">Sin progreso</h3>
                            <p class="text-sm text-pixel-text-secondary">No ves tu crecimiento</p>
                        </div>
                        <div class="bg-pixel-card border-2 border-red-600 p-6 shadow-pixel">
                            <div class="text-3xl mb-2">😔</div>
                            <h3 class="font-bold text-gaming-health mb-2">Desmotivación</h3>
                            <p class="text-sm text-pixel-text-secondary">Pierdes interés rápido</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Sección 3: La Solución (reemplazada por ParallaxProductivity) -->
        <ParallaxProductivity lang="es" />

        <!-- Sección 4: Galería "Instagrammable" -->
        <section class="py-20 px-4 bg-pixel-bg2 hidden">
            <div class="container mx-auto text-center">
                <h2 class="text-3xl md:text-5xl font-bold mb-6 font-poppins">
                    Diseñado para que <span class="text-gaming-gold">presumas</span> tu progreso
                </h2>
                <p class="text-xl text-pixel-text-secondary mb-12 max-w-2xl mx-auto">
                    Capturas de pantalla que querrás compartir en todas tus redes sociales
                </p>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
                    <!-- Mockup 1 -->
                    <div class="bg-pixel-card border-2 border-pixel-border shadow-pixel p-6 hover:shadow-pixel-hover hover:border-gaming-gold transition-all duration-300 transform hover:-translate-y-2">
                        <div class="aspect-[9/16] bg-gradient-to-b from-gaming-purple to-gaming-blue rounded-lg mb-4 flex items-center justify-center text-6xl">
                            📊
                        </div>
                        <h3 class="font-bold text-lg mb-2">Perfil de Aventurero</h3>
                        <p class="text-pixel-text-secondary text-sm">Tu progreso en cada skill, nivel actual y próximas recompensas</p>
                    </div>
                    
                    <!-- Mockup 2 -->
                    <div class="bg-pixel-card border-2 border-pixel-border shadow-pixel p-6 hover:shadow-pixel-hover hover:border-gaming-gold transition-all duration-300 transform hover:-translate-y-2">
                        <div class="aspect-[9/16] bg-gradient-to-b from-gaming-cyan to-gaming-blue rounded-lg mb-4 flex items-center justify-center text-6xl">
                            📈
                        </div>
                        <h3 class="font-bold text-lg mb-2">Resumen Semanal</h3>
                        <p class="text-pixel-text-secondary text-sm">Tu "Spotify Wrapped" personal con las skills que más subieron</p>
                    </div>
                    
                    <!-- Mockup 3 -->
                    <div class="bg-pixel-card border-2 border-pixel-border shadow-pixel p-6 hover:shadow-pixel-hover hover:border-gaming-gold transition-all duration-300 transform hover:-translate-y-2">
                        <div class="aspect-[9/16] bg-gradient-to-b from-gaming-gold to-accent-500 rounded-lg mb-4 flex items-center justify-center text-6xl">
                            🎉
                        </div>
                        <h3 class="font-bold text-lg mb-2">¡Misión Completada!</h3>
                        <p class="text-pixel-text-secondary text-sm">Animación épica cuando subes de nivel y desbloqueas rewards</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Sección 6: CTA Final -->
        <section class="py-20 px-4 bg-pixel-bg2">
            <div class="container mx-auto text-center">
                <h2 class="text-3xl md:text-5xl font-bold mb-6 font-poppins">
                    ¿Listo para Gamificar <span class="text-gaming-gold">tu Vida Real</span>?
                </h2>
                <p class="text-xl text-pixel-text-secondary mb-12 max-w-2xl mx-auto">
                    Tu aventura de crecimiento personal comienza ahora. Descarga Skillion y convierte cada día en una épica quest de superación personal.
                </p>
                
                <div class="pixel-frame pixel-corners-white p-8 max-w-2xl mx-auto mb-8">
                    <PreRegisterForm 
                        idform='pre-register-form-2'
                        lang="es"
                        accountId="1681493"
                        formId="166304992625428354"
                    />
                </div>
                
                <div class="flex justify-center items-center gap-4 text-pixel-text-secondary text-sm">
                    <span>⚔️</span>
                    <span>Derrota al boss de la procrastinación</span>
                    <span>🏆</span>
                    <span>Forja tu leyenda</span>
                    <span>🎮</span>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="py-12 px-4 border-t-2 border-pixel-border">
            <div class="container mx-auto text-center">
                <div class="text-4xl mb-4">🎮</div>
                <h3 class="text-2xl font-bold mb-2 text-gaming-gold font-poppins">Skillion</h3>
                <p class="text-pixel-text-secondary mb-6">Gamifica tu vida real. La app RPG de productividad y hábitos.</p>
                
                <div class="flex justify-center gap-6 mb-8">
                    <a href="https://instagram.com/skillion.app" class="text-pixel-text-secondary hover:text-gaming-gold transition-colors" aria-label="Skillion en Instagram">Instagram</a>
                    <a href="https://instagram.com/skillion.es" class="text-pixel-text-secondary hover:text-gaming-gold transition-colors" aria-label="Skillion España en Instagram">Instagram ES</a>
                    <a href="https://tiktok.com/@skillion.app" class="text-pixel-text-secondary hover:text-gaming-gold transition-colors" aria-label="Skillion en TikTok">TikTok</a>
                </div>
                
                <div class="flex justify-center gap-6 mb-8">
                    <a href="/es/" class="text-pixel-text-secondary hover:text-gaming-gold transition-colors">Inicio</a>
                    <a href="/es/contact" class="text-pixel-text-secondary hover:text-gaming-gold transition-colors">Contacto</a>
                    <a href="/es/privacy" class="text-pixel-text-secondary hover:text-gaming-gold transition-colors">Política de Privacidad</a>
                </div>
                
                <!-- SEO Content Footer -->
                <div class="text-xs text-pixel-text-secondary mb-4 max-w-4xl mx-auto">
                    <p class="mb-2">
                        <strong>Skillion</strong> es la aplicación líder en gamificación personal que transforma tus hábitos diarios en una experiencia RPG inmersiva. 
                        Nuestra plataforma de productividad gamificada te ayuda a mantener la motivación, crear rutinas duraderas y alcanzar tus metas personales 
                        mediante mecánicas de juego probadas. Únete a miles de usuarios que ya están subiendo de nivel en la vida real.
                    </p>
                </div>
                
                <p class="text-xs text-pixel-text-secondary">
                    © 2025 Skillion. Hecho con ❤️ y mucho ☕ para gamificar vidas extraordinarias.
                </p>
            </div>
        </footer>
    </main>

    <!-- Inicialización global de parallax (igual que en la página EN) -->
    <script type="module">
        // Inline parallax functionality to avoid TypeScript import issues
        function clamp(n, min = 0, max = 1) {
            return Math.max(min, Math.min(max, n));
        }

        function initParallax() {
            console.log('initParallax: Starting initialization...');
            
            const containers = Array.from(
                document.querySelectorAll('[data-parallax-root], [data-parallax-root-rewards]')
            );
            
            console.log('initParallax: Found', containers.length, 'containers');
            
            if (!containers.length) {
                console.warn('Parallax: No containers found with [data-parallax-root] or [data-parallax-root-rewards]');
                return;
            }

            const activeLayers = new Set();

            // Observe visibility (perf) - more lenient threshold
            const io = new IntersectionObserver(
                (entries) => {
                    entries.forEach((e) => {
                        const layers = e.target.querySelectorAll('.parallax-layer');
                        layers.forEach((l) => {
                            if (e.isIntersecting) activeLayers.add(l);
                            else activeLayers.delete(l);
                        });
                    });
                },
                { root: null, threshold: 0, rootMargin: '100px' }
            );

            containers.forEach((c) => io.observe(c));

            let ticking = false;
            const onScroll = () => {
                if (ticking) return;
                ticking = true;
                requestAnimationFrame(() => {
                    update();
                    ticking = false;
                });
            };

            const getScrollY = () => {
                // Cross-browser scroll position (iOS/Safari quirks)
                return window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
            };

            const update = () => {
                const scrollY = getScrollY();

                containers.forEach((container) => {
                    const rect = container.getBoundingClientRect();
                    const containerTop = rect.top + window.scrollY;
                    const containerH = container.offsetHeight || 1;

                    // progress: 0 when container top hits top of viewport; 1 near container bottom
                    const progress = clamp((scrollY - containerTop) / containerH);

                    const layers = container.querySelectorAll('.parallax-layer');

                    if (layers.length === 0) {
                        console.warn('initParallax: No .parallax-layer elements found in container');
                    }

                    layers.forEach((layer) => {
                        // Always apply parallax when container is in view, regardless of activeLayers
                        const speedX = parseFloat(layer.dataset.speedX || '0');
                        const speedY = parseFloat(layer.dataset.speedY || '0');
                        const dirX = parseFloat(layer.dataset.dirX || '1');
                        const dirY = parseFloat(layer.dataset.dirY || '1');

                        const baseX = parseFloat(layer.dataset.baseX || '0'); // px offset if you want
                        const baseY = parseFloat(layer.dataset.baseY || '0');

                        // Translate based on window scroll (simple, smooth)
                        const translateX = baseX + scrollY * speedX * dirX;
                        const translateY = baseY + scrollY * speedY * dirY;

                        // Store scroll-based transform in data attributes for cursor follow to use
                        layer.dataset.scrollX = String(translateX);
                        layer.dataset.scrollY = String(translateY);

                        // Apply transform (cursor follow may override this)
                        layer.style.transform = `translate3d(${translateX}px, ${translateY}px, 0)`;

                        // Fade by progress
                        if (layer.dataset.fade === 'true') {
                            const start = parseFloat(layer.dataset.fadeStart || '0.2');
                            const end = parseFloat(layer.dataset.fadeEnd || '0.7');
                            let opacity = 1;
                            if (progress <= start) opacity = 1;
                            else if (progress >= end) opacity = 0;
                            else opacity = 1 - (progress - start) / (end - start);
                            layer.style.opacity = String(clamp(opacity, 0, 1));
                        } else {
                            layer.style.opacity = '1';
                        }
                    });
                });
            };

            // Kick off
            // Ensure DOM is ready before first update
            setTimeout(() => {
                update();
            }, 100);
            
            window.addEventListener('scroll', onScroll, { passive: true });
            document.addEventListener('scroll', onScroll, { passive: true });
            window.addEventListener('resize', () => {
                // A resize changes geometry -> re-run once
                requestAnimationFrame(update);
            });
        }
        
        // Initialize parallax for all containers (hero + rewards)
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', () => {
                initParallax();
            });
        } else {
            initParallax();
        }
    </script>
</Layout>

<style>
    /* Efectos adicionales para mejorar la experiencia pixel art */
    @keyframes glitch {
        0% { transform: translate(0) }
        20% { transform: translate(-2px, 2px) }
        40% { transform: translate(-2px, -2px) }
        60% { transform: translate(2px, 2px) }
        80% { transform: translate(2px, -2px) }
        100% { transform: translate(0) }
    }
    
    .hover\:animate-glitch:hover {
        animation: glitch 0.3s ease-in-out;
    }
</style>


