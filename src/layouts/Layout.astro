---
import '../styles/global.css';
import GoogleAnalytics from "../components/GoogleAnalytics.astro";
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from "@vercel/speed-insights/astro";

export interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	lang?: string;
}

const { 
	title, 
	description = "Skillion - La app que gamifica tu vida real. Convierte tus hábitos en un RPG, gana XP por cada tarea completada y sube de nivel en la vida real. Descarga la app de gamificación de hábitos más divertida.",
	ogImage = "/assets/Skillion.png",
	lang = "es"
} = Astro.props;

const urlEs = new URL('/es/', Astro.url);
const urlEn = new URL('/', Astro.url);
const site = 'https://skillion.app';
const isSpanish = (lang === 'es');
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="author" content="Skillion Team" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={Astro.url} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="Skillion" />
		<meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />

		<!-- Hreflang alternates -->
		<link rel="alternate" hreflang="es" href={urlEs} />
		<link rel="alternate" hreflang="es-ES" href={urlEs} />
		<link rel="alternate" hreflang="en" href={urlEn} />
		<link rel="alternate" hreflang="en-US" href={urlEn} />
		<link rel="alternate" hreflang="x-default" href={urlEn} />
		
		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImage} />
		<meta property="twitter:creator" content="@skillion_app" />
		
		<!-- Additional SEO -->
		<meta name="theme-color" content="#90c5bf" />
		<meta name="application-name" content="Skillion" />
		<meta name="apple-mobile-web-app-title" content="Skillion" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="default" />
		
		<!-- Schema.org markup for Skillion -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": "Skillion",
			"description": "App de gamificación que convierte tus hábitos y metas en una aventura RPG. Gana XP en la vida real por cada tarea que completas.",
			"url": "https://skillion.app",
			"applicationCategory": "ProductivityApplication",
			"operatingSystem": "iOS, Android",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			},
			"aggregateRating": {
				"@type": "AggregateRating",
				"ratingValue": "4.8",
				"ratingCount": "1000"
			},
			"creator": {
				"@type": "Organization",
				"name": "Skillion Team"
			},
			"keywords": "gamificación, hábitos, productividad, RPG, XP, vida real, motivación, metas"
		}
		</script>
		
	<!-- Poppins font now loaded from local files in global.css for better performance -->
	<link rel="preload" href="/fonts/Poppins-Regular.ttf" as="font" type="font/ttf" crossorigin>
	<link rel="preload" href="/fonts/Poppins-Bold.ttf" as="font" type="font/ttf" crossorigin>
	
	<!-- VT323 font loaded asynchronously (non-blocking) -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
	<noscript><link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet"></noscript>
	</head>
	<body class="font-poppins">
		<GoogleAnalytics />
		<Analytics />
		<SpeedInsights />

		<!-- Language Switcher -->
		<nav class="fixed top-3 right-3 z-50 pointer-events-auto">
			<select 
				id="language-selector" 
				class="bg-gray-900/80 backdrop-blur-sm text-white text-sm font-poppins border-2 border-gaming-gold rounded px-3 py-1 outline-none cursor-pointer hover:bg-gray-800/90 transition-colors"
				aria-label="Select language"
			>
				<option value="en" selected={!isSpanish}>🇺🇸 EN</option>
				<option value="es" selected={isSpanish}>🇪🇸 ES</option>
			</select>
		</nav>

		<script>
		  (function(){
			try {
			  var select = document.getElementById('language-selector') as HTMLSelectElement;
			  if (!select) return;
			  
			  // Get current path and determine language
			  var currentPath = window.location.pathname;
			  var isEsPath = currentPath.startsWith('/es/') || currentPath === '/es';
			  
			  // Set correct selection on page load
			  select.value = isEsPath ? 'es' : 'en';
			  
			  select.addEventListener('change', function(e){
				var target = e.target as HTMLSelectElement;
				if (!target) return;
				var selectedLang = target.value;
				
				// Save preference
				try { 
				  localStorage.setItem('preferredLang', selectedLang); 
				} catch(err) {}
				
				// Determine target URL based on current path
				var targetUrl = '/';
				
				// Get the path without /es/ prefix
				var pathWithoutLang = currentPath.replace(/^\/es\//, '/').replace(/^\/es$/, '/');
				
				if (selectedLang === 'es') {
				  // Going to Spanish version
				  if (pathWithoutLang === '/') {
					targetUrl = '/es/';
				  } else {
					targetUrl = '/es' + pathWithoutLang;
				  }
				} else {
				  // Going to English version
				  targetUrl = pathWithoutLang;
				}
				
				window.location.href = targetUrl;
			  });
			} catch(e) {}
		  })();
		</script>

		<slot />
	</body>
</html>
