---
interface Props {
  idform?: string;
  lang?: 'en' | 'es';
  accountId?: string; // MailerLite account
  formId?: string;    // MailerLite webform id (HTML embed)
  placeholder?: string;
  buttonText?: string;
}

const { 
  idform = 'preregister-form',
  lang = 'es',
  accountId = '',
  formId = '',
  placeholder = lang === 'es' ? 'tu-email@aventurero.com' : 'player@email.com',
  buttonText = lang === 'es' ? '¡Quiero acceso anticipado!' : 'Get early access'
} = Astro.props;
---

<form id={idform} class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto" method="post" target={`hidden_iframe_${idform}`} action={`https://assets.mailerlite.com/jsonp/${accountId}/forms/${formId}/subscribe`}>
  <div class="flex-1 pixel-input p-1 bg-white/95">
    <input 
      type="email"
      name="fields[email]"
      placeholder={placeholder}
      required
      autocomplete="email"
      class="w-full px-3 py-2 bg-white text-gray-800 placeholder-pixel-text-secondary rounded-none font-poppins border-0 outline-none focus:outline-none focus:ring-0"
    />
  </div>
  <button 
    type="submit"
    class="pixel-button px-6 py-3 bg-gaming-gold text-gaming-dark font-poppins font-bold border-2 border-yellow-600 shadow-pixel hover:shadow-pixel-hover hover:bg-yellow-400 hover:shadow-glow transform hover:-translate-y-1 active:translate-y-0 active:shadow-pixel transition-all duration-300 whitespace-nowrap"
  >
    {buttonText}
  </button>
  <input type="hidden" name="ml-submit" value="1" />
  <input type="hidden" name="anticsrf" value="true" />
</form>
<iframe name={`hidden_iframe_${idform}`} style="display:none"></iframe>

<script define:vars={{ formId: idform, preferredLang: lang }}>
  const formElement = document.getElementById(formId);
  formElement?.addEventListener('submit', function(){
    try {
      const emailInput = formElement.querySelector('input[name="fields[email]"]');
      const email = emailInput && 'value' in emailInput ? emailInput.value : '';
      const submitButton = formElement.querySelector('button[type="submit"]');
      const originalText = submitButton ? submitButton.textContent : '';
      if (submitButton) {
        submitButton.textContent = preferredLang === 'es' ? 'Registrando...' : 'Registering...';
        submitButton.disabled = true;
        submitButton.classList.add('opacity-75','cursor-not-allowed');
      }
      setTimeout(() => {
        if (submitButton) {
          submitButton.textContent = originalText || '';
          submitButton.disabled = false;
          submitButton.classList.remove('opacity-75','cursor-not-allowed');
        }
        const url = `/gracias?lang=${encodeURIComponent(preferredLang)}&email=${encodeURIComponent(email || '')}`;
        window.location.href = url;
      }, 1200);
    } catch(_) {}
  });
</script>
