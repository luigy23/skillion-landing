---
interface Props {
  placeholder?: string;
  buttonText?: string;
  idform?: string;
  lang?: 'en' | 'es';
}

const { 
  placeholder = 'tu-email@aventurero.com',
  buttonText = '¡Quiero acceso anticipado!',
  idform = 'preregister-form',
  lang = 'es'
} = Astro.props;
---

<form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto" id={idform}>
  <div class="flex-1 pixel-input p-1 bg-white/95">
    <input 
      type="email" 
      name="email"
      placeholder={placeholder}
      required
      class="w-full px-3 py-2 bg-white text-gray-800 placeholder-pixel-text-secondary rounded-none font-poppins border-0 outline-none focus:outline-none focus:ring-0"
    />
  </div>
  <button 
    type="submit"
    class="pixel-button px-6 py-3 bg-gaming-gold text-gaming-dark font-poppins font-bold border-2 border-yellow-600 shadow-pixel hover:shadow-pixel-hover hover:bg-yellow-400 hover:shadow-glow transform hover:-translate-y-1 active:translate-y-0 active:shadow-pixel transition-all duration-300 whitespace-nowrap"
  >
    {buttonText}
  </button>
</form>

<script define:vars={{ formId: idform, preferredLang: lang }}>
 // La variable "formId" viene desde el frontmatter gracias a define:vars
  const formElement = document.getElementById(formId);

  // Language-specific text
  const text = {
    en: {
      loading: 'Registering...',
      success: 'Registered! Redirecting...',
      error: 'Error registering email',
      connectionError: 'Connection error. Please try again.',
      registered: 'Registered! Redirecting...'
    },
    es: {
      loading: 'Registrando...',
      success: '¡Registrado! Redirigiendo...',
      error: 'Error al registrar el email',
      connectionError: 'Error de conexión. Inténtalo de nuevo.',
      registered: '¡Registrado! Redirigiendo...'
    }
  };

  const currentText = text[preferredLang] || text.es;

  formElement?.addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const form = e.target;
    const submitButton = form.querySelector('button[type="submit"]');
    const originalButtonText = submitButton.textContent;
    const emailInput = form.querySelector('input[name="email"]');
    
    // Mostrar estado de carga
    submitButton.disabled = true;
    submitButton.textContent = currentText.loading;
    submitButton.classList.add('opacity-75', 'cursor-not-allowed');
    
    try {
      const email = emailInput.value;
      
      const response = await fetch('/api/subscribe', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ email })
      });
      
      const result = await response.json();
      
      if (result.success) {
        showNotification(currentText.success, 'success');
        form.reset();
        setTimeout(() => {
          var url = `/gracias?lang=${encodeURIComponent(preferredLang)}&email=${encodeURIComponent(email)}`;
          window.location.href = url;
        }, 1500);
      } else {
        showNotification(result.message || currentText.error, 'error');
        // Si hay error, restauramos el botón aquí
        submitButton.disabled = false;
        submitButton.textContent = originalButtonText;
        submitButton.classList.remove('opacity-75', 'cursor-not-allowed');
      }
      
    } catch (error) {
      console.error('Error:', error);
      showNotification(currentText.connectionError, 'error');
      // Si hay error, también restauramos el botón
      submitButton.disabled = false;
      submitButton.textContent = originalButtonText;
      submitButton.classList.remove('opacity-75', 'cursor-not-allowed');
    }
    // El bloque finally ya no es necesario si manejas la restauración del botón en los casos de error.
  });
  
  
  function showNotification(message, type) {
    // Crear notificación personalizada en lugar de alert
    const notification = document.createElement('div');
    notification.className = `fixed top-4 right-4 p-4 rounded-lg shadow-lg z-50 max-w-sm notification-enter ${
      type === 'success' 
        ? 'bg-white text-gaming-dark border-2 border-yellow-600' 
        : 'bg-gaming-health text-white border-2 border-red-600'
    }`;
    
    notification.innerHTML = `
      <div class="flex items-center gap-2">
        <span class="text-xl">${type === 'success' ? '🎮' : '⚠️'}</span>
        <p class="font-poppins font-bold">${message}</p>
      </div>
    `;
    
    document.body.appendChild(notification);
    
    // Animar entrada
    setTimeout(() => {
      notification.classList.remove('notification-enter');
      notification.classList.add('notification-show');
    }, 100);
    
    // Para mensajes de éxito (que redirigen), mostrar menos tiempo
    const displayTime = type === 'success' ? 2000 : 5000;
    
    // Remover después del tiempo especificado
    setTimeout(() => {
      notification.classList.remove('notification-show');
      notification.classList.add('notification-exit');
      setTimeout(() => notification.remove(), 300);
    }, displayTime);
  }
</script>
