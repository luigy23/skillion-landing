---
import FeatureCard from './FeatureCard.astro';
import { Image } from 'astro:assets';
import InstagramIcon from './../assets/pixelartAssets/icons/ig_icon.png';
import TikTokIcon from './../assets/pixelartAssets/icons/tt_icon.png';
import { rewardsParallax } from '../config/parallax-config.ts';

interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'en' } = Astro.props as Props;

// Reward Asset URLs
import grassUrl from "./../assets/pixelartAssets/rewards/grass.png";
import knightUrl from "./../assets/pixelartAssets/rewards/knight.png";
import tree2Url from "./../assets/pixelartAssets/rewards/tree2.png";

// Generate config for all breakpoints
const rewardsConfig = JSON.stringify(rewardsParallax);

const content = {
  en: {
    heading1: 'How Skillion Gamifies Your Productivity',
    subheading1: 'Discover the gamified productivity app that turns your daily routine into your most epic adventure',
    card1Title: 'Customize Your Real-Life Skills',
    card1Body: "Create unique skills like 'Fitness', 'Programming', 'Reading' or 'Networking'. With Skillion, every area of your life becomes an RPG skill you can level up.",
    card2Title: 'Missions that Transform Habits',
    card2Body: 'Every daily task (workout, study, work) becomes an epic quest. Complete challenges and earn real XP that reflects in your life progress.',
    card3Title: 'Gamified Progress System',
    card3Body: 'Watch XP bars grow, unlock unique achievements and customize your journey. Gamification makes habit-building addictively fun.',
    heading2: 'Join the Personal Gamification Revolution',
    subheading2: 'Be part of the pioneer community gamifying their lives with Skillion. Early access, exclusive rewards, and the chance to shape the future of gamified productivity.',
    socialInstagram: 'Instagram',
    socialInstagramEs: 'Instagram ES',
    socialTikTok: 'TikTok',
    betaTitle: 'Skillion Beta Rewards',
    betaBody: 'Early adopters get exclusive beta access, extended trial and special launch discounts. Be a pioneer in gamifying your life!'
  },
  es: {
    heading1: 'Cómo Skillion Gamifica tu Productividad',
    subheading1: 'Descubre la app de gamificación que convierte tu rutina diaria en tu aventura más épica',
    card1Title: 'Personaliza tus Skills de Vida Real',
    card1Body: "Crea habilidades únicas como 'Fitness', 'Programación', 'Lectura' o 'Networking'. Con Skillion, cada área de tu vida se convierte en una skill RPG que puedes subir de nivel.",
    card2Title: 'Misiones que Transforman Hábitos',
    card2Body: 'Cada tarea diaria (ejercicio, estudio, trabajo) se convierte en una misión épica. Completa challenges y gana XP real que se refleja en tu progreso de vida.',
    card3Title: 'Sistema de Progreso Gamificado',
    card3Body: 'Observa barras de XP crecer, desbloquea achievements únicos y personaliza tu aventura. La gamificación hace que mantener hábitos sea adictivamente divertido.',
    heading2: 'Únete a la Revolución de la Gamificación Personal',
    subheading2: 'Forma parte de la comunidad de pioneros que están gamificando su vida con Skillion. Acceso anticipado, recompensas exclusivas y la oportunidad de influir en el futuro de la productividad gamificada.',
    socialInstagram: 'Instagram',
    socialInstagramEs: 'Instagram ES',
    socialTikTok: 'TikTok',
    betaTitle: 'Recompensas Beta de Skillion',
    betaBody: 'Los early adopters de Skillion recibirán acceso beta exclusivo, periodo de prueba extendido y descuentos especiales en el lanzamiento. ¡Sé pionero en gamificar tu vida!'
  }
} as const;

const t = content[lang];
---

<section
  id="productivity-section"
  class="relative w-full min-h-screen overflow-visible"
  style="background-color: #97b7d1;"
>
  <!-- Parallax container for reward assets -->
  <div data-parallax-root-rewards class="absolute inset-0 overflow-visible pointer-events-none">
    <img id="parallax-grass" src={grassUrl.src} alt={lang === 'es' ? 'Césped' : 'Grass'}
         class="absolute pixel-art" />
    <img id="parallax-knight" src={knightUrl.src} alt={lang === 'es' ? 'Caballero' : 'Knight'}
         class="absolute pixel-art" />
    <img id="parallax-tree2" src={tree2Url.src} alt={lang === 'es' ? 'Árbol' : 'Tree 2'}
         class="absolute pixel-art" />
  </div>

  <!-- Content -->
  <div class="relative z-10 py-16 px-4">
    <div class="container mx-auto max-w-6xl">
      <!-- First Section: How Skillion Gamifies Your Productivity -->
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold mb-4 font-poppins text-gray-800">
          {lang === 'es' ? 'Cómo ' : 'How '}<span class="text-shine">Skillion</span> {lang === 'es' ? 'Gamifica ' : 'Gamifies '}<span class="text-gaming-gold">{lang === 'es' ? 'tu Productividad' : 'Your Productivity'}</span>
        </h2>
        <p class="text-lg md:text-xl text-white max-w-2xl mx-auto">
          {t.subheading1}
        </p>
      </div>
      
      <!-- Simple grid layout for cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
        <FeatureCard 
          icon="🧠"
          title={t.card1Title}
        >
          {t.card1Body}
        </FeatureCard>
        
        <FeatureCard 
          icon="⚔️"
          title={t.card2Title}
        >
          {t.card2Body}
        </FeatureCard>
        
        <FeatureCard 
          icon="🏆"
          title={t.card3Title}
          class="md:col-span-2 md:col-start-1 md:justify-self-center md:max-w-md lg:col-span-1 lg:col-start-auto lg:justify-self-auto lg:max-w-none"
        >
          {t.card3Body}
        </FeatureCard>
      </div>

      <!-- Second Section: Join the Personal Gamification Revolution -->
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold mb-6 font-poppins text-gray-800 text-stroke-blue">
          {lang === 'es' 
            ? 'Únete a la Revolución de la Gamificación Personal' 
            : 'Join the Personal Gamification Revolution'}
        </h2>
        <p class="text-lg md:text-xl text-white mb-12 max-w-2xl mx-auto">
          {t.subheading2}
        </p>
        
        <div class="flex justify-center gap-4 mb-12">
          <div class="social-button-container">
            <a href="https://instagram.com/skillion.app" target="_blank" class="pixel-btn pixel-instagram">
              <Image src={InstagramIcon} alt="Instagram" class="w-8 h-8 md:w-10 md:h-10 pixel-art" />
            </a>
            <span class="social-title">{t.socialInstagram}</span>
          </div>
          
          <div class="social-button-container">
            <a href="https://instagram.com/skillion_es" target="_blank" class="pixel-btn pixel-instagram">
              <Image src={InstagramIcon} alt="Instagram ES" class="w-8 h-8 md:w-10 md:h-10 pixel-art" />
            </a>
            <span class="social-title">{t.socialInstagramEs}</span>
          </div>
          
          <div class="social-button-container">
            <a href="https://tiktok.com/@skillion.app" target="_blank" class="pixel-btn pixel-tiktok">
              <Image src={TikTokIcon} alt="TikTok" class="w-8 h-8 md:w-10 md:h-10 pixel-art" />
            </a>
            <span class="social-title">{t.socialTikTok}</span>
          </div>
        </div>
        
        <div class="bg-white/80 backdrop-blur-sm pixel-frame p-4 md:p-6 mb-25 max-w-4xl mx-auto hero-text-container">
          <div class="text-4xl mb-4">🎁</div>
          <h3 class="text-xl md:text-2xl font-bold mb-4 text-gaming-gold">{t.betaTitle}</h3>
          <p class="text-base md:text-lg lg:text-xl leading-relaxed font-poppins text-gray-800">
            {t.betaBody}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .social-button-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .social-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: #374151;
    text-align: center;
    font-family: 'Poppins', sans-serif;
    padding-top: 0.25rem;
  }

  .shadow-glow {
    box-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
  }

  /* Enhanced card styling for better visual appeal */
  .feature-card {
    transition: all 0.3s ease;
    transform: translateY(0);
  }

  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.2);
  }

  /* Enhanced section styling */
  #productivity-section {
    position: relative;
    overflow: hidden;
  }

  #productivity-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, transparent 50%, rgba(0, 0, 0, 0.05) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Mobile-first responsive adjustments */
  @media (min-width: 640px) {
    .social-button-container {
      gap: 1.25rem;
    }
    
    .social-title {
      font-size: 0.875rem;
      padding-top: 0.5rem;
    }
  }

  @media (min-width: 1024px) {
    .social-button-container {
      gap: 1.5rem;
    }
    
    .social-title {
      font-size: 1rem;
      padding-top: 0.75rem;
    }
  }
</style>

<!-- Client script: configure + start rewards parallax -->
<script type="module" define:vars={{ rewardsConfig }}>
  
  // Parse the config passed from server
  const rewardsParallax = JSON.parse(rewardsConfig);

  const root = document.querySelector('[data-parallax-root-rewards]');

  function currentBreakpoint() {
    const w = window.innerWidth;
    if (w < 640) return 'mobile';
    if (w < 1024) return 'tablet';
    return 'desktop';
  }

  function applyRewardsConfig(root) {
    const cfg = rewardsParallax[currentBreakpoint()];
    const map = {
      'parallax-grass': 'grass',
      'parallax-knight': 'knight',
      'parallax-tree2': 'tree2',
    };

    Object.entries(map).forEach(([id, key]) => {
      const el = root.querySelector('#' + id);
      if (!el) return;
      const c = cfg[key];

      // Reset conflicting inline positioning first
      ['top','right','bottom','left','width','height'].forEach((p) => {
        el.style[p] = '';
      });

      // Position & size (independent per breakpoint)
      Object.entries(c.pos).forEach(([k, v]) => (el.style[k] = v));
      Object.entries(c.size).forEach(([k, v]) => (el.style[k] = v));
      el.style.zIndex = String(c.z);

      // Parallax data
      el.classList.add('parallax-layer');
      el.dataset.speedX = String(c.speedX ?? 0);
      el.dataset.speedY = String(c.speedY ?? 0);
      el.dataset.dirX = String(c.dirX ?? 1);
      el.dataset.dirY = String(c.dirY ?? 1);
      if (c.fade) {
        el.dataset.fade = 'true';
        el.dataset.fadeStart = String(c.fadeStart ?? 0.2);
        el.dataset.fadeEnd = String(c.fadeEnd ?? 0.7);
      } else {
        el.dataset.fade = 'false';
      }

      // Quality & perf
      el.style.willChange = 'transform, opacity';
      el.style.imageRendering = 'pixelated';
    });
  }

  function applyNow() {
    if (root) {
      console.log('ParallaxProductivity: Applying rewards config to', root);
      applyRewardsConfig(root);
      
      // Debug: Check if elements have the right classes and data attributes
      const layers = root.querySelectorAll('.parallax-layer');
      console.log('ParallaxProductivity: Found', layers.length, 'parallax layers');
      
      layers.forEach((layer, index) => {
        console.log(`Layer ${index}:`, {
          id: layer.id,
          speedX: layer.dataset.speedX,
          speedY: layer.dataset.speedY,
          dirX: layer.dataset.dirX,
          dirY: layer.dataset.dirY
        });
      });
    } else {
      console.warn('ParallaxProductivity: No rewards parallax root found');
    }
  }

  // Wait for DOM to be ready before initializing
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      applyNow();
      // Don't call initParallax() here as it might be called by the hero section
    });
  } else {
    // DOM is already ready
    applyNow();
    // Don't call initParallax() here as it might be called by the hero section
  }

  // Re-apply positions & speeds on resize/orientation change
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      applyNow();
    }, 120);
  });
  window.addEventListener('orientationchange', () => {
    console.log('ParallaxProductivity: Orientation change detected, reapplying config...');
    applyNow();
  });
</script>
