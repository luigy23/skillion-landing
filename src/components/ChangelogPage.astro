---
import ChangelogTimeline from './ChangelogTimeline.astro';
import { changelogUi, type Lang } from '../data/changelog';
import Image from 'astro/components/Image.astro';
import Logo from '../assets/Skillion.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const homeHref = lang === 'es' ? '/es/' : '/';
const otherLangHref = lang === 'es' ? '/updates' : '/es/novedades';
const otherLangLabel = lang === 'es' ? 'EN' : 'ES';
---

<!-- Fantasy display serif for headings -->
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700;800&display=swap"
/>

<main class="fantasy-page min-h-screen">
  <!-- Top nav bar -->
  <header class="quest-nav sticky top-0 z-20">
    <div class="container mx-auto flex items-center justify-between gap-4 px-4 py-3">
      <a href={homeHref} class="flex items-center gap-2 transition-transform hover:-translate-y-0.5">
        <Image src={Logo} alt="Skillion" class="h-9 w-9 rounded-lg" />
        <span class="font-cinzel text-lg font-bold tracking-wide text-[#f0d98a]">Skillion</span>
      </a>

      <div class="flex items-center gap-3">
        <a
          href={homeHref}
          class="hidden text-sm text-[#d8c79a] transition-colors hover:text-[#f6e3a1] sm:inline"
        >
          ← {changelogUi.backHome[lang]}
        </a>
        <a href={otherLangHref} class="quest-pill text-xs font-bold">
          🌐 {otherLangLabel}
        </a>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="px-4 pt-16 pb-6 text-center">
    <p class="mb-4 font-cinzel text-sm font-semibold uppercase tracking-[0.35em] text-[#c9a227]">
      ✦ {changelogUi.heroEyebrow[lang]} ✦
    </p>
    <h1 class="fantasy-title mb-5 text-5xl font-extrabold md:text-7xl">
      {changelogUi.heroTitle[lang]}
    </h1>
    <p class="mx-auto max-w-2xl text-lg leading-relaxed text-[#e4d5ac] md:text-xl">
      {changelogUi.heroSubtitle[lang]}
    </p>

    <!-- Ornamental divider -->
    <div class="quest-divider mx-auto mt-8 max-w-md" aria-hidden="true">
      <span class="quest-divider__line"></span>
      <span class="quest-divider__gem">✦</span>
      <span class="quest-divider__line"></span>
    </div>
  </section>

  <!-- Timeline -->
  <section class="px-4 pb-16">
    <ChangelogTimeline lang={lang} />
  </section>

  <!-- Thanks / closing -->
  <section class="px-4 pb-20">
    <div class="parchment mx-auto max-w-2xl p-8 text-center md:p-10">
      <div class="mb-4 text-4xl">🏆</div>
      <h2 class="font-cinzel mb-2 text-2xl font-bold text-[#5a3d12] md:text-3xl">
        {changelogUi.thanksTitle[lang]}
      </h2>
      <p class="mb-7 text-[#6b5836]">{changelogUi.thanksText[lang]}</p>
      <a href={homeHref} class="quest-button inline-block">
        ⚔️ {changelogUi.backHome[lang]}
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-[#6e4f25]/60 px-4 py-10 text-center">
    <div class="mb-2 text-3xl">🎲</div>
    <h3 class="font-cinzel mb-1 text-xl font-bold text-[#f0d98a]">Skillion</h3>
    <p class="text-sm text-[#b8a577]">
      © 2025 Skillion. {lang === 'es' ? 'Gamifica tu vida real.' : 'Gamify your real life.'}
    </p>
  </footer>
</main>

<style is:global>
  .font-cinzel {
    font-family: 'Cinzel', serif;
  }

  /* Warm, deep fantasy backdrop — not pure black, no neon. */
  .fantasy-page {
    background:
      radial-gradient(1100px 480px at 50% -8%, rgba(201, 162, 39, 0.16), transparent 60%),
      radial-gradient(900px 600px at 100% 100%, rgba(94, 31, 31, 0.18), transparent 65%),
      linear-gradient(180deg, #20170c 0%, #150f08 100%);
  }

  .quest-nav {
    background: linear-gradient(180deg, #2c1f11 0%, #211810 100%);
    border-bottom: 2px solid #6e4f25;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.45);
  }

  .quest-pill {
    color: #f0d98a;
    background: linear-gradient(180deg, #3a2a17, #2a1d10);
    border: 2px solid #8a6a32;
    padding: 0.4rem 0.75rem;
    box-shadow: 0 2px 0 rgba(0, 0, 0, 0.35);
    transition: all 0.25s ease;
  }
  .quest-pill:hover {
    border-color: #d8b545;
    transform: translateY(-1px);
  }

  /* Gold gilded title with a soft (not neon) shadow. */
  .fantasy-title {
    font-family: 'Cinzel', serif;
    background: linear-gradient(180deg, #fbeaa7 0%, #e3bb4e 45%, #b3852f 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    filter: drop-shadow(0 2px 3px rgba(0, 0, 0, 0.5));
  }

  /* Ornamental divider */
  .quest-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .quest-divider__line {
    flex: 1;
    height: 2px;
    background: linear-gradient(90deg, transparent, #b08d4e, transparent);
  }
  .quest-divider__gem {
    color: #d8b545;
    font-size: 1.1rem;
  }

  /* Aged parchment card — high contrast, fully readable. */
  .parchment {
    position: relative;
    background:
      radial-gradient(140px 90px at 12% 8%, rgba(120, 90, 40, 0.10), transparent 70%),
      radial-gradient(180px 130px at 88% 92%, rgba(120, 90, 40, 0.12), transparent 70%),
      linear-gradient(160deg, #f4e8ca 0%, #e8d7ad 100%);
    color: #3a2c17;
    border: 3px solid #6e4f25;
    box-shadow:
      inset 0 0 0 2px #c9a86b,
      0 12px 30px rgba(0, 0, 0, 0.5);
    border-radius: 4px;
  }

  /* Wooden plaque button */
  .quest-button {
    font-family: 'Cinzel', serif;
    font-weight: 700;
    color: #2a1c0a;
    background: linear-gradient(180deg, #f3d066 0%, #d8b545 50%, #b3852f 100%);
    border: 2px solid #8a6a32;
    padding: 0.75rem 2rem;
    box-shadow: 0 4px 0 #7a5a26, 0 8px 18px rgba(0, 0, 0, 0.4);
    transition: all 0.2s ease;
  }
  .quest-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 0 #7a5a26, 0 12px 22px rgba(0, 0, 0, 0.45);
  }
  .quest-button:active {
    transform: translatey(2px);
    box-shadow: 0 2px 0 #7a5a26;
  }

  /* Rarity tags (fantasy chips) */
  .tag {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    border: 1px solid;
  }
  .tag--legendary {
    color: #6b4a0d;
    background: linear-gradient(180deg, #f6da7e, #e3bb4e);
    border-color: #b3852f;
  }
  .tag--rare {
    color: #11304a;
    background: linear-gradient(180deg, #bfe0f2, #8fc0db);
    border-color: #4f87a8;
  }
  .tag--enchanted {
    color: #103a26;
    background: linear-gradient(180deg, #b7e6c4, #7fc99a);
    border-color: #3e7d5a;
  }
</style>
